#version 460 core

#extension GL_EXT_shader_8bit_storage: require
#extension GL_EXT_mesh_shader: require

#define MAX_VERTICES 64
#define MAX_TRIANGLES 42
layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = MAX_VERTICES, max_primitives = MAX_TRIANGLES) out;

struct Vertex
{
    float vx, vy, vz;
    float nx, ny, nz;
    float tu, tv;
};

layout(binding = 0) readonly buffer VertexBuffer
{
    Vertex vertices[];
};

struct Meshlet
{
    uint vertexIndices[MAX_VERTICES];
    uint8_t triangleIndices[MAX_TRIANGLES * 3];
    uint8_t triangleCount;
    uint8_t vertexCount;
};

layout(binding = 1) readonly buffer MeshletBuffer
{
    Meshlet meshlets[];
};

layout(location = 0) out vec4 v_Color[];

void main()
{
    uint mi  = gl_WorkGroupID.x;
    uint tid = gl_LocalInvocationIndex;

    uint vertexCount   = uint(meshlets[mi].vertexCount);
    uint triangleCount = uint(meshlets[mi].triangleCount);

    SetMeshOutputsEXT(vertexCount, triangleCount);

    if (tid < vertexCount)
    {
        uint vi  = meshlets[mi].vertexIndices[tid];
        Vertex v = vertices[vi];
        vec3 position = vec3(v.vx, v.vy, v.vz);
        vec3 normal   = vec3(v.nx, v.ny, v.nz);
        gl_MeshVerticesEXT[tid].gl_Position = vec4(position + vec3(0, 0, 0.5), 1.0);
        v_Color[tid] = vec4(normal * 0.5 + 0.5, 1.0);
    }

    if (tid < triangleCount)
    {
        gl_PrimitiveTriangleIndicesEXT[tid] = uvec3(
            uint(meshlets[mi].triangleIndices[tid * 3 + 0]),
            uint(meshlets[mi].triangleIndices[tid * 3 + 1]),
            uint(meshlets[mi].triangleIndices[tid * 3 + 2])
        );
    }
}